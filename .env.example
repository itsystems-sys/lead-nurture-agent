# --- Close CRM ---
CLOSE_API_KEY=
CLOSE_BASE_URL=https://api.close.com/api/v1
CLOSE_WEBHOOK_SECRET=

# Custom field IDs (Settings -> Custom Fields -> open field -> URL contains cf_xxx)
CLOSE_CF_BOOKING_DATE=
CLOSE_CF_CALL_TIME=
CLOSE_CF_CALENDLY_LINK=
CLOSE_CF_LEAD_TIMEZONE=
CLOSE_CF_MEETING_TYPE=
CLOSE_CF_MRR=
CLOSE_CF_BUSINESS_TYPE=

# Opportunity status IDs (Settings -> Pipelines -> URL contains stat_xxx)
CLOSE_STATUS_CALL_BOOKED=
CLOSE_STATUS_CALL_RESCHEDULED=
CLOSE_STATUS_CALL_CANCELLED=
CLOSE_STATUS_CALL_COMPLETED=
CLOSE_STATUS_CONTACT_SENT=
CLOSE_STATUS_WON=
CLOSE_STATUS_OPPORTUNITY_LOST=
CLOSE_STATUS_FOLLOW_UP=

# Close LEAD status IDs (lifecycle layer)
CLOSE_LEAD_STATUS_POTENTIAL=
CLOSE_LEAD_STATUS_NURTURE=
CLOSE_LEAD_STATUS_QUALIFIED=
CLOSE_LEAD_STATUS_CLIENT=
CLOSE_LEAD_STATUS_UNQUALIFIED=
CLOSE_LEAD_STATUS_LOST=
CLOSE_LEAD_STATUS_BAD_FIT=
CLOSE_LEAD_STATUS_CANCELLED=

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
# IANA timezone for rendering call_time in emails/SMS (e.g. America/Los_Angeles, Asia/Manila).
APP_DISPLAY_TIMEZONE=UTC

# Org-wide default links used when a lead has no per-lead value.
APP_DEFAULT_CALENDAR_LINK=
APP_DEFAULT_CASE_STUDY_LINK=

# --- Retention ---
# Leads older than this are purged daily at 03:00 UTC.
LEAD_RETENTION_DAYS=180

# --- Retry policy ---
# Per-job send budget. After this many failed attempts the job is marked failed.
MAX_SEND_ATTEMPTS=3
# Seconds to wait before retrying a transient failure.
RETRY_DELAY_SECONDS=300

# --- Email dispatch ---
# log  = record rendered email to data/logs.json (no network) - good for dev/test
# smtp = send via the SMTP server configured below
EMAIL_PROVIDER=log

# SMTP settings (only used when EMAIL_PROVIDER=smtp)
# Port 587 = STARTTLS (most providers, blocked by some ISPs).
# Port 465 = implicit TLS / SMTPS (used automatically when SMTP_PORT=465).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=no-reply@example.com

# --- SMS dispatch ---
# log    = record rendered SMS to data/logs.json (no network) - good for dev/test
# twilio = send via Twilio REST API using the credentials below
# none   = SMS disabled (any SMS step will be marked failed)
SMS_PROVIDER=log

# Twilio settings (only used when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
